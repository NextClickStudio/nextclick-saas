generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                String      @id @default(cuid())
  shopDomain        String      @unique
  accessToken       String
  email             String?
  ownerName         String?
  planName          String      @default("starter")
  planStatus        String      @default("pending")
  billingId         String?
  generationsUsed   Int         @default(0)
  generationsLimit  Int         @default(1000)
  billingCycleStart DateTime    @default(now())
  installedAt       DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  isActive          Boolean     @default(true)

  config      ShopConfig?
  products    Product[]
  generations Generation[]
  sessions    ShopSession[]

  @@map("shops")
}

model ShopConfig {
  id              String  @id @default(cuid())
  shopId          String  @unique
  shop            Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  category        String  @default("beauty")
  logoUrl         String?
  primaryColor    String  @default("#0A0A0A")
  secondaryColor  String  @default("#00E676")
  bgColor         String  @default("#FFFFFF")
  textColor       String  @default("#0A0A0A")
  buttonColor     String  @default("#0A0A0A")
  buttonTextColor String  @default("#FFFFFF")
  fontFamily      String  @default("Inter")
  borderRadius    String  @default("8px")

  brandName     String  @default("My Brand")
  heroTitle     String  @default("Trova la tua routine perfetta")
  heroSubtitle  String  @default("Personalizzata per te dall intelligenza artificiale")
  ctaText       String  @default("Inizia ora")
  loadingText   String  @default("Sto analizzando il tuo profilo...")

  questionFlow    Json    @default("[]")
  aiPersona       String  @default("Sei un esperto consulente. Fornisci consigli personalizzati e professionali.")
  aiTone          String  @default("professionale")
  aiLanguage      String  @default("it")

  featureRoutine  Boolean @default(false)
  featureProducts Boolean @default(true)
  featurePdf      Boolean @default(false)

  widgetPosition  String  @default("bottom-right")
  widgetTrigger   String  @default("button")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shop_configs")
}

model Product {
  id           String  @id @default(cuid())
  shopId       String
  shop         Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shopifyId    String
  title        String
  handle       String
  url          String
  imageUrl     String?
  price        Float?
  comparePrice Float?
  category     String?
  tags         String[] @default([])
  goals        String[] @default([])
  skinTypes    String[] @default([])
  description  String?
  isActive     Boolean  @default(true)
  isAiManaged  Boolean  @default(true)
  syncedAt     DateTime @default(now())

  @@unique([shopId, shopifyId])
  @@map("products")
}

model Generation {
  id            String  @id @default(cuid())
  shopId        String
  shop          Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sessionId     String?
  answers       Json
  resultType    String
  productsCount Int     @default(0)
  tokensUsed    Int     @default(0)
  durationMs    Int     @default(0)
  error         Boolean @default(false)
  errorMessage  String?
  createdAt     DateTime @default(now())

  clicks ProductClick[]

  @@map("generations")
}

model ProductClick {
  id           String     @id @default(cuid())
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  shopifyId    String
  productTitle String
  price        Float?
  createdAt    DateTime   @default(now())

  @@map("product_clicks")
}

model ShopSession {
  id        String   @id
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("shop_sessions")
}
